# Plantbase — kornyezeti valtozok sablonja. Masold '.env'-be es toltsd ki.
# A valodi '.env' NEM kerul gitbe (lasd .gitignore).

# --- Adatbazis (docker-compose Postgres) ---
# Read-write: Prisma migracio + seed (owner szerep).
DATABASE_URL="postgresql://plantbase:plantbase@localhost:5433/plantbase?schema=public"
# Read-only: az agent runSql toolja (csak SELECT, kulon szerep).
DATABASE_URL_READONLY="postgresql://plantbase_ro:plantbase_ro@localhost:5433/plantbase?schema=public"

# --- Anthropic (a B2 fazistol kell) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- MCP szerverekhez (fejlesztoi eszkozok) ---
GITHUB_PAT=ghp_...
CONTEXT7_API_KEY=ctx7sk-...
