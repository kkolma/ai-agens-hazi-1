// Plantbase adatbazis-sema (Prisma).
// A modell mezonevei szandekosan snake_case-ek, hogy a kesz seed (seed/plants.ts)
// valtoztatas nelkul mukodjon, es a runSql nyers SQL is a sema szerinti oszlopneveket lassa.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// Novenykatalogus — a domain kozponti tablaja (stack.md szerint).
model Product {
  id                Int      @id @default(autoincrement())
  name              String
  latin_name        String
  category          String
  location          String
  price             Decimal  @db.Decimal(10, 2)
  sale_price        Decimal? @db.Decimal(10, 2)
  stock             Int
  light             String
  watering          String
  difficulty        String
  current_height_cm Int
  max_height_cm     Int
  current_pot_cm    Int
  pet_safe          Boolean
  kid_safe          Boolean
  air_purifying     Boolean
  rating            Decimal  @db.Decimal(3, 2)
  reviews_count     Int
  description       String

  @@map("products")
}
